{
    "name": "agenticorchestrator/agenticorchestrator",
    "description": "A Laravel AI Agent framework with multi-tenancy, workflows, RAG pipelines, and evaluation tools",
    "keywords": [
        "laravel",
        "ai",
        "agent",
        "llm",
        "openai",
        "anthropic",
        "multi-tenancy",
        "workflow",
        "orchestration"
    ],
    "license": "MIT",
    "type": "library",
    "support": {
        "email": "agenticorchestrator@proton.me",
        "issues": "https://github.com/agenticOrchestrator/agenticorchestrator/issues"
    },
    "authors": [
        {
            "name": "Evangelos Dimitriadis",
            "email": "agenticorchestrator@proton.me"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/contracts": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "illuminate/database": "^11.0|^12.0|^13.0",
        "illuminate/events": "^11.0|^12.0|^13.0",
        "illuminate/cache": "^11.0|^12.0|^13.0",
        "illuminate/queue": "^11.0|^12.0|^13.0",
        "echolabsdev/prism": "^0.99",
        "guzzlehttp/guzzle": "^7.8"
    },
    "require-dev": {
        "laravel/pint": "^1.18",
        "nunomaduro/collision": "^8.0|^9.0",
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "pestphp/pest": "^3.0|^4.0",
        "pestphp/pest-plugin-laravel": "^3.0|^4.0",
        "phpstan/phpstan": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0"
    },
    "suggest": {
        "pinecone-io/pinecone-php": "Required for Pinecone vector store",
        "qdrant/qdrant-php": "Required for Qdrant vector store",
        "weaviate/weaviate-php": "Required for Weaviate vector store",
        "pgvector/pgvector": "Required for PgVector store",
        "livewire/livewire": "Required for optional dashboard components"
    },
    "autoload": {
        "psr-4": {
            "AgenticOrchestrator\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AgenticOrchestrator\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "analyse": "vendor/bin/phpstan analyse",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "AgenticOrchestrator\\AgenticOrchestratorServiceProvider"
            ],
            "aliases": {
                "Agent": "AgenticOrchestrator\\Facades\\Agent",
                "Memory": "AgenticOrchestrator\\Facades\\Memory",
                "Tenant": "AgenticOrchestrator\\Facades\\Tenant"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
