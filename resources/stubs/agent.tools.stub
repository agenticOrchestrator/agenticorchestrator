    /**
     * Get the agent's system instructions.
     */
    public function instructions(): string
    {
        return <<<'INSTRUCTIONS'
        You are a helpful AI assistant with access to tools.

        Use the available tools when appropriate to help the user.
        Be concise and helpful in your responses.
        INSTRUCTIONS;
    }

    /**
     * Example tool method - look up information.
     *
     * Replace this with your actual tool implementation.
     */
    #[Tool('Look up information by ID')]
    public function lookupInfo(
        #[ToolParameter('The ID to look up')]
        string $id,
    ): array {
        // TODO: Implement your tool logic here
        return [
            'id' => $id,
            'status' => 'found',
            'data' => [],
        ];
    }

    /**
     * Example tool method - perform a search.
     *
     * Replace this with your actual tool implementation.
     */
    #[Tool('Search for items matching a query')]
    public function search(
        #[ToolParameter('The search query')]
        string $query,
        #[ToolParameter('Maximum number of results', enum: ['10', '25', '50'])]
        string $limit = '10',
    ): array {
        // TODO: Implement your tool logic here
        return [
            'query' => $query,
            'limit' => (int) $limit,
            'results' => [],
        ];
    }
